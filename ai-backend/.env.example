# ─── OpenRouter (single API key for all 5 AI models) ───────────────
# Sign up at https://openrouter.ai and get your key
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx

# ─── Solana / MagicBlock ───────────────────────────────────────────
# Base layer RPC (devnet)
SOLANA_RPC_URL=https://api.devnet.solana.com

# MagicBlock Ephemeral Rollups endpoint (~50ms latency)
ER_RPC_URL=https://devnet-router.magicblock.app

# Set to "true" after deploying the on-chain program with `anchor deploy`
ON_CHAIN=false

# Wallet private key (JSON array of bytes) or path to keypair file
# WALLET_PRIVATE_KEY=[1,2,3,...]
# WALLET_PATH=~/.config/solana/id.json

# ─── ElevenLabs TTS (optional — AI voices for each player) ────────
# Sign up at https://elevenlabs.io and get your API key
# ELEVENLABS_API_KEY=xi-xxxxxxxxxxxx

# ─── Server ────────────────────────────────────────────────────────
PORT=3001

# Timing (milliseconds)
HAND_DELAY_MS=3000
ACTION_DELAY_MS=1200
BETTING_WINDOW_MS=15000
COOLDOWN_MS=20000
